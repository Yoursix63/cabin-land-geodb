# Copy to .env and fill in. .env is gitignored.

# PostgreSQL / PostGIS connection
PGHOST=localhost
PGPORT=5432
PGDATABASE=cabin_land
PGUSER=postgres
PGPASSWORD=

# Project geographic anchor (drive-time origin)
ORIGIN_NAME=Alexandria, VA
ORIGIN_LAT=38.8048
ORIGIN_LON=-77.0469
DRIVE_TIME_MINUTES=180

# Optional routing service for isochrone (osrm | valhalla | ors)
ROUTING_BACKEND=osrm
ROUTING_URL=
ORS_API_KEY=
